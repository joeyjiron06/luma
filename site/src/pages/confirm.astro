---
import ConfirmSignup from "@/components/ConfirmSignup";
import NavBar from "@/components/landingPage/sections/navBar";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Luma" htmlClass="dark">
  <div class="relative min-h-screen bg-background">
    <div class="z-10 flex min-h-screen flex-col">
      <NavBar />

      <main class="container flex flex-1 items-center justify-center py-12">
        <ConfirmSignup client:load />
      </main>
    </div>
  </div>
</BaseLayout>
