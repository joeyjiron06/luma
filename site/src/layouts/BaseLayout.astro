---
import "../pages/index.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  themeColor?: string;
  htmlClass?: string;
  bodyClass?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "Luma is an AI background noise removal app that sounds like you.",
  ogImage = "https://luma.pub/preview.png",
  ogUrl = "https://luma.pub",
  themeColor = "#000000",
  htmlClass = "",
  bodyClass = "min-h-screen bg-background text-foreground",
  jsonLd,
} = Astro.props;
---

<html lang="en" class={htmlClass}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={themeColor} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="GNP3JM5BsETUsVvuMI-hqFPeFspOwiQ9ONXnTTeZEk0" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Luma" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-ldFD_bN-Cv6dOhyc-7koN.js"
    ></script>
    <script>
      // @ts-ignore
      ((window.plausible =
        window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        }),
        (plausible.init =
          plausible.init ||
          function (i) {
            plausible.o = i || {};
          }));
      plausible.init();
    </script>

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    <link rel="sitemap" href="/sitemap-index.xml" />

    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
